@{
}

<h3>Users</h3>
@{
 var usersObj = ViewBag.Users;
 var usersEnumerable = usersObj as IEnumerable<dynamic>;
}

@if (usersEnumerable != null)
{
 <table class="table">
 <thead>
 <tr>
 <th>User ID</th>
 <th>Name</th>
 <th>Email</th>
 <th></th>
 </tr>
 </thead>
 <tbody>
 @foreach (var u in usersEnumerable)
 {
 <tr>
 <td>@u.UserId</td>
 <td>@u.FullName</td>
 <td>@u.Email</td>
 <td><a asp-action="OrderHistory" asp-route-userId="@u.UserId">View Orders</a></td>
 </tr>
 }
 </tbody>
 </table>
}
else if (usersObj != null)
{
 // If ViewBag.Users is not a list, show it as a summary value (e.g., analytics count)
 <p><strong>Users:</strong> @usersObj</p>
}
else
{
 <p>No users found.</p>
}