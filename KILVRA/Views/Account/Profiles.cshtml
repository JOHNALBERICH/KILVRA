@model KILVRA.Models.User
@{
    ViewData["Title"] = "AccountDetail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <div class="row">
        <!-- Left Profile Info -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body text-center p-4">
                    
                    <h4 class="fw-bold mb-0">@Model.FullName</h4>
                    <p class="text-muted mb-1">@Model.Email</p>
                    <p class="text-muted small">@Model.Address</p>

                    <hr class="my-3" />

                    <div class="d-grid gap-2">
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-box-arrow-right me-1"></i> Logout
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Main Info -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-3 mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">🛍 Order History</h5>
                </div>
                <div class="card-body">
                    @if (Model.Orders != null && Model.Orders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table align-middle table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Order #</th>
                                        <th>Date</th>
                                        <th>Items</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.Orders)
                                    {
                                        <tr>
                                            <td class="fw-bold text-primary">#@order.OrderId</td>
                                            <td>@order.OrderDate.ToString()</td>
                                            <td>
                                                <ul class="list-unstyled mb-0">
                                                    @foreach (var item in order.OrderDetails)
                                                    {
                                                        <li>@item.Product.Name <span class="text-muted">x@item.Quantity</span></li>
                                                    }
                                                </ul>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center mb-0">No orders found.</p>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">❤️ Favorite Products</h5>
                </div>
                <div class="card-body">
                    @if (Model.Favorites != null && Model.Favorites.Any())
                    {
                        <div class="row">
                            @foreach (var favorite in Model.Favorites)
                            {
                                <div class="col-md-4 col-sm-6 mb-4">
                                    <div class="card border-0 shadow-sm h-100 text-center">
                                        <img src="@favorite.Product.ImageUrl"
                                             alt="@favorite.Product.Name"
                                             class="card-img-top rounded-top"
                                             style="height: 180px; object-fit: cover;" />
                                        <div class="card-body">
                                            <h6 class="card-title">@favorite.Product.Name</h6>
                                            <p class="text-muted mb-2">$@favorite.Product.Price</p>
                                            <a asp-controller="Shop" asp-action="Details" asp-route-id="@favorite.ProductId"
                                               class="btn btn-sm btn-outline-primary">View Product</a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center mb-0">No favorite products yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>