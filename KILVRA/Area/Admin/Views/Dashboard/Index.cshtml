@{
 ViewData["Title"] = "Index";
 Layout = "~/Area/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Dashboard</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">Dashboard</li>
    </ol>

    <div class="row">
        <div class="col-xl-6">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fas fa-chart-area me-1"></i>
                    Area Chart
                </div>
                <div class="card-body"><canvas id="myAreaChart" width="100%" height="40"></canvas></div>
            </div>
        </div>
        <div class="col-xl-6">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fas fa-chart-bar me-1"></i>
                    Bar Chart
                </div>
                <div class="card-body"><canvas id="myBarChart" width="100%" height="40"></canvas></div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @using Newtonsoft.Json
    <script>
        const chartData = @Html.Raw(JsonConvert.SerializeObject(ViewBag.ChartData));

        // AREA CHART (Revenue)
        const ctxRevenue = document.getElementById('myAreaChart');
        new Chart(ctxRevenue, {
            type: 'line',
            data: {
                labels: chartData.map(x => x.Day),
                datasets: [{
                    label: 'Revenue ($)',
                    data: chartData.map(x => x.Revenue),
                    fill: true,
                    borderColor: '#4e73df',
                    backgroundColor: 'rgba(78, 115, 223, 0.1)',
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } }
            }
        });

        // BAR CHART (Users)
        const ctxUsers = document.getElementById('myBarChart');
        new Chart(ctxUsers, {
            type: 'bar',
            data: {
                labels: chartData.map(x => x.Day),
                datasets: [{
                    label: 'Active Users',
                    data: chartData.map(x => x.Users),
                    backgroundColor: '#1cc88a'
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    </script>
    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-table me-1"></i>
            Order History
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-5">
                    @Html.Partial("UsersList")
                </div>
                <div class="col-md-7">
                    @Html.Partial("OrderHistory", ViewBag.Orders as IEnumerable<KILVRA.Models.Order>)
                </div>
            </div>
        </div>
    </div>
</div>

