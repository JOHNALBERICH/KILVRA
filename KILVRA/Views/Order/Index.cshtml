@model IEnumerable<KILVRA.Models.Product>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Cart Start -->
<div class="container-fluid pt-5">
    <div class="row px-xl-5">
        <div class="col-lg-8 table-responsive mb-5">
            <table class="table table-bordered text-center mb-0">
                <thead class="bg-secondary text-dark">
                    <tr>
                        <th>Products</th>
                        <form asp-controller="Order" asp-action="AddCart" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@ViewBag.ProductId" />
                            <input type="hidden" name="qty" value="1" />

                            <select name="size" required class="form-control form-control-sm d-inline w-auto">
                                <option value="">Size</option>
                                <option>S</option>
                                <option>M</option>
                                <option>L</option>
                                <option>XL</option>
                            </select>

                            <button type="submit" class="btn btn-sm text-dark p-0 ml-1">
                                <i class="fas fa-shopping-cart text-primary mr-1"></i>Add
                            </button>
                        </form>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Total</th>
                        <th>Remove</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @if(Model!=null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            if (item == null)
                            {
                                continue; // skip bad data
                            }
                            <tr>
                                <td class="align-middle"><img src="@Url.Content(item.ImageUrl)" alt="@item.Name" style="max-width:100px;max-height:100px;" /> @item.Name</td>
                                <td class="align-middle">@item.Size</td>
                                <td class="align-middle">@item.Price.ToString("N0") VND</td>
                                <td class="align-middle">
                                    <div class="input-group input-group-sm mx-auto" style="width: 100px;">
                                        <form asp-controller="Order" asp-action="UpdateQuantity" method="post" style="display:inline;">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="hidden" name="quantity" value="@(item.Quantity - 1)" />
                                            <button class="btn btn-primary btn-minus" type="submit"><i class="fa fa-minus"></i></button>
                                        </form>
                                        <input type="text" class="form-control text-center" value="@item.Quantity" readonly />
                                        <form asp-controller="Order" asp-action="UpdateQuantity" method="post" style="display:inline;">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="hidden" name="quantity" value="@(item.Quantity + 1)" />
                                            <button class="btn btn-primary btn-plus" type="submit"><i class="fa fa-plus"></i></button>
                                        </form>
                                    </div>
                                </td>
                                <td class="align-middle">@((item.Price * (item.Quantity ?? 1)).ToString("N0")) VND</td>
                                <td class="align-middle">
                                    <form asp-controller="Order" asp-action="RemoveFromCart" method="post" style="display:inline;">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <input type="hidden" name="size" value="@item.Size" />
                                        <button class="btn btn-sm btn-danger" type="submit" style="background:#c99b94;border:none;width:32px;height:32px;line-height:1;padding:0;">
                                            <span style="font-size:1.5rem;line-height:1;">&times;</span>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="align-middle">No products in the cart.</td>
                        </tr>
					}
                </tbody>
            </table>
        </div>
        <div class="col-lg-4">
            <form class="mb-5" action="">
                <div class="input-group">
                    <input type="text" class="form-control p-4" placeholder="Coupon Code">
                    <div class="input-group-append">
                        <button class="btn btn-primary">Apply Coupon</button>
                    </div>
                </div>
            </form>
            <div class="card border-secondary mb-5">
                <div class="card-header bg-secondary border-0">
                    <h4 class="font-weight-semi-bold m-0">Cart Summary</h4>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3 pt-1">
                        <h6 class="font-weight-medium">Subtotal</h6>
                        <h6 class="font-weight-medium">@((ViewBag.Subtotal ?? 0).ToString("N0")) VND</h6>
                    </div>
                    <div class="d-flex justify-content-between">
                        <h6 class="font-weight-medium">Shipping</h6>
                        <h6 class="font-weight-medium">@((ViewBag.Shipping ?? 0).ToString("N0")) VND</h6>
                    </div>
                </div>
                <div class="card-footer border-secondary bg-transparent">
                    <div class="d-flex justify-content-between mt-2">
                        <h5 class="font-weight-bold">Total</h5>
                        <h5 class="font-weight-bold">@((ViewBag.Total ?? 0).ToString("N0")) VND</h5>
                    </div>
                    <button class="btn btn-block btn-primary my-3 py-3">Proceed To Checkout</button>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Cart End -->
